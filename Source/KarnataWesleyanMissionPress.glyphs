    sub kn_v    from [kn_v_v];
    sub kn_sh   from [kn_sh_v];
    sub kn_ss   from [kn_ss_v];
    sub kn_s    from [kn_s_v];
    sub kn_h    from [kn_h_v];";
tag = aalt;
},
{
code = "    # Post-base Substitutions
    # explicit one-to-one mappings (required: RHS must be concrete glyph)

    sub kn_k   kn_virama by kn_k_v;
    sub kn_kh  kn_virama by kn_kh_v;
    sub kn_g   kn_virama by kn_g_v;
    sub kn_gh  kn_virama by kn_gh_v;
    sub kn_ng  kn_virama by kn_ng_v;
    sub kn_c   kn_virama by kn_c_v;
    sub kn_ch  kn_virama by kn_ch_v;
    sub kn_j   kn_virama by kn_j_v;
    sub kn_jh  kn_virama by kn_jh_v;
    sub kn_ny  kn_virama by kn_ny_v;

    sub kn_tt  kn_virama by kn_tt_v;
    sub kn_tth kn_virama by kn_tth_v;
    sub kn_dd  kn_virama by kn_dd_v;
    sub kn_ddh kn_virama by kn_ddh_v;
    sub kn_nn  kn_virama by kn_nn_v;
    sub kn_t   kn_virama by kn_t_v;
    sub kn_th  kn_virama by kn_th_v;
    sub kn_d   kn_virama by kn_d_v;
    sub kn_dh  kn_virama by kn_dh_v;
    sub kn_n   kn_virama by kn_n_v;

    sub kn_p   kn_virama by kn_p_v;
    sub kn_ph  kn_virama by kn_ph_v;
