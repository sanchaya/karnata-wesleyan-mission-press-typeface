features = (
{
code = "    sub kn_arka_ottu    from [kn_r_ottu];
    sub kn_k    from [kn_k_v];
    sub kn_kh   from [kn_kh_v];
    sub kn_g    from [kn_g_v];
    sub kn_gh   from [kn_gh_v];
